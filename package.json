{
  "name": "ellucian-banner",
  "version": "0.1.0",
  "description": "Node.js SDK for Ellucian Banner — Ethos Integration and native Banner REST APIs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/ && prettier --check src/ test/",
    "lint:fix": "eslint --fix src/ test/ && prettier --write src/ test/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ellucian",
    "banner",
    "ethos",
    "higher-education",
    "sis",
    "student-information-system",
    "eedm",
    "api-client"
  ],
  "author": "Wyre Tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chatt-state/ellucian-banner.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
